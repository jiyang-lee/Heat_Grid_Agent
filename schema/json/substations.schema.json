{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heatgrid.agent/schema/substations.schema.json",
  "title": "substations",
  "description": "기계실 설비 마스터(정적). configuration_types.csv + source metadata 기준. contract version operational_input_v1.",
  "type": "object",
  "additionalProperties": false,
  "required": ["substation_id", "manufacturer"],
  "properties": {
    "substation_id": {
      "type": "integer",
      "description": "기계실 식별자(PK)",
      "minimum": 0
    },
    "manufacturer": {
      "type": "string",
      "enum": ["manufacturer 1", "manufacturer 2"]
    },
    "configuration_type": {
      "type": ["string", "null"],
      "enum": [
        "sh",
        "sh_dhw",
        "sh_dhw_with_sub_circuits",
        "sh_with_buffer_tank",
        "sh_with_sub_circuits",
        "missing",
        null
      ]
    },
    "has_dhw": { "type": ["boolean", "null"] },
    "has_buffer_tank": { "type": ["boolean", "null"] },
    "source_file": { "type": ["string", "null"] },
    "created_at": { "type": ["string", "null"], "format": "date-time" },
    "updated_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
