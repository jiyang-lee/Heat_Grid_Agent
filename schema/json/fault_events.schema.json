{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://heatgrid.agent/schema/fault_events.schema.json",
  "title": "fault_events",
  "description": "고장 신고 이력 1건. faults.csv 운영 필요 컬럼만(훈련 전용 컬럼 제외). days_since_last_fault_event 계산 원천. contract version operational_input_v1.",
  "type": "object",
  "additionalProperties": false,
  "required": ["event_id", "substation_id", "report_date"],
  "properties": {
    "event_id": { "type": "integer", "description": "faults.csv Event ID(PK)" },
    "substation_id": { "type": "integer", "minimum": 0 },
    "report_date": { "type": "string", "format": "date-time" },
    "problem_en": { "type": ["string", "null"] },
    "fault_label": { "type": ["string", "null"] },
    "event_description_en": { "type": ["string", "null"] },
    "created_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
