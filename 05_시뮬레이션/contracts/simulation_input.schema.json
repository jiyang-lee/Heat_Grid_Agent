{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HeatGrid Simulation Input",
  "type": "object",
  "required": [
    "scenario_id",
    "generated_at",
    "priority_card",
    "model_detection",
    "rag_answer",
    "connection_check",
    "db_mapping"
  ],
  "properties": {
    "scenario_id": {
      "type": "string",
      "description": "시뮬레이션 화면에서 구분할 대표 사례 ID"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time",
      "description": "이 JSON이 생성된 시각"
    },
    "priority_card": {
      "type": "object",
      "required": ["rank", "risk_level", "reason", "recommended_action"],
      "properties": {
        "rank": {
          "type": "integer",
          "minimum": 1
        },
        "risk_level": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "reason": {
          "type": "string"
        },
        "recommended_action": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "model_detection": {
      "type": "object",
      "required": [
        "manufacturer",
        "substation_id",
        "detected_label",
        "risk_score",
        "window_start",
        "window_end"
      ],
      "properties": {
        "manufacturer": {
          "type": "string",
          "description": "PreDist 제조사 그룹. substation_id만으로는 전역 고유 키가 아니므로 함께 사용한다."
        },
        "substation_id": {
          "type": "string"
        },
        "detected_label": {
          "type": "string",
          "description": "예: normal, pre_fault, fault"
        },
        "risk_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "window_start": {
          "type": "string",
          "format": "date-time"
        },
        "window_end": {
          "type": "string",
          "format": "date-time"
        },
        "top_signals": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "value", "unit", "status"],
            "properties": {
              "name": {
                "type": "string"
              },
              "value": {
                "type": ["number", "string"]
              },
              "unit": {
                "type": "string"
              },
              "status": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "rag_answer": {
      "type": "object",
      "required": ["summary", "evidence", "check_points"],
      "properties": {
        "summary": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source", "text"],
            "properties": {
              "source": {
                "type": "string"
              },
              "text": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "check_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "connection_check": {
      "type": "object",
      "required": ["matched", "basis", "missing_items"],
      "properties": {
        "matched": {
          "type": "boolean"
        },
        "basis": {
          "type": "string"
        },
        "missing_items": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "db_mapping": {
      "type": "object",
      "required": ["site_name", "facility_name", "equipment", "sensor_keys"],
      "properties": {
        "site_name": {
          "type": "string"
        },
        "facility_name": {
          "type": "string"
        },
        "equipment": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sensor_keys": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
