# 지도: MapLibre GL JS + MapTiler 다크 스타일.
# 이 파일을 `.env`로 복사한 뒤 값을 채운다 (.env는 커밋 금지, .env.example엔 실제 키를 넣지 말 것).
#
# VITE_MAP_STYLE_URL 에는 다음 중 하나를 넣는다:
#   - MapTiler 키 문자열만 (예: YOUR_MAPTILER_KEY) → 코드가 다크 스타일 URL을 조립
#   - 또는 전체 style JSON URL (예: https://api.maptiler.com/maps/dataviz-dark/style.json?key=...)
# MapTiler 키는 브라우저 노출 클라이언트 키다 → MapTiler 대시보드에서 Allowed origins 제한을 걸 것.
VITE_MAP_STYLE_URL=
#
# (대안) Protomaps pmtiles 자체 호스팅 방식으로 갈 경우 사용. 키 불필요.
# VITE_MAP_PMTILES_URL=

# 백엔드 프록시 대상. 기본값은 현재 로컬 백엔드 포트와 동일한 8002.
VITE_BACKEND_URL=http://127.0.0.1:8002

# API 소스. 기본(미설정)=실백엔드. 데모 mock이 필요하면 true.
# VITE_USE_MOCK=false
