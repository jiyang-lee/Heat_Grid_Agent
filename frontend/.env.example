# 지도: MapLibre GL JS + 기본 CARTO 다크 타일.
# 전체 MapLibre style JSON URL을 사용할 때만 VITE_MAP_STYLE_URL을 설정한다.
# 비워두거나 예전 MapTiler 키만 있으면 별도 키가 필요 없는 기본 지도를 사용한다.
VITE_MAP_STYLE_URL=
#
# (대안) Protomaps pmtiles 자체 호스팅 방식으로 갈 경우 사용. 키 불필요.
# VITE_MAP_PMTILES_URL=

# 백엔드 프록시 대상. 기본값은 현재 로컬 백엔드 포트와 동일한 8003.
VITE_BACKEND_URL=http://127.0.0.1:8003

# API 소스. 기본(미설정)=실백엔드. 데모 mock이 필요하면 true.
# VITE_USE_MOCK=false
