OPENAI_API_KEY=
# 팀원별 개인 키를 입력한다. 이 파일이나 Git에는 실제 키를 넣지 않는다.
HEATGRID_NATURAL_CHAT_MODEL=gpt-5.4-mini
HEATGRID_WORK_ORDER_MODEL=gpt-5.4-nano
HEATGRID_REPORT_MODEL=gpt-5.4-nano
HEATGRID_INTEGRATED_AGENT_MODEL=gpt-5.4-mini
HEATGRID_INDEPENDENT_AGENT_MODEL=gpt-5.4-mini
HEATGRID_REJUDGE_MODEL=gpt-5.4
KMA_SERVICE_KEY=
HEATGRID_RAG_URL=http://127.0.0.1:8011
HEATGRID_DATABASE_URL=postgresql+asyncpg://heatgrid:heatgrid@127.0.0.1:55432/heatgrid_ops
HEATGRID_API_PORT=8003
HEATGRID_AGENT_MAX_ITERATIONS=4
HEATGRID_AGENT_EVIDENCE_THRESHOLD=0.75
HEATGRID_MODEL_SCORE_TOLERANCE=0.12
HEATGRID_EXTERNAL_SEARCH_ENABLED=0
HEATGRID_EXTERNAL_SEARCH_MODEL=gpt-5.4-mini
HEATGRID_EXTERNAL_SEARCH_MAX_RESULTS=5
HEATGRID_EXTERNAL_SEARCH_ALLOWED_DOMAINS=
HEATGRID_RETRAIN_AUTO_EXECUTE_ENABLED=0
HEATGRID_PRIORITY_EXPECTED_SUBSTATIONS=31
HEATGRID_PRIORITY_STALE_AFTER_HOURS=720
HEATGRID_PRIORITY_MODEL_VERSION=active-priority-contract-v1
HEATGRID_RAG_BACKEND=auto
HEATGRID_DISABLE_WEATHER=0
