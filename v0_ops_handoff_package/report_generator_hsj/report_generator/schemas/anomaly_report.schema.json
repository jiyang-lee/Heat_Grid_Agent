{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://heatgrid.local/schemas/anomaly_report.schema.json",
  "title": "HeatGrid Anomaly Report",
  "description": "Priority Card 1건과 Agent Output JSON을 기반으로 생성되는 이상징후 보고서 JSON 계약입니다.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_metadata",
    "target_asset",
    "priority_summary",
    "situation_summary",
    "key_evidence",
    "risk_analysis",
    "suspected_causes",
    "recommended_actions",
    "work_order_summary",
    "evidence_references",
    "operator_note",
    "rendering_hints"
  ],
  "properties": {
    "report_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "report_id",
        "report_type",
        "schema_version",
        "generated_at",
        "language",
        "source_card_id"
      ],
      "properties": {
        "report_id": {
          "type": "string",
          "minLength": 1,
          "description": "보고서 고유 ID입니다."
        },
        "report_type": {
          "type": "string",
          "const": "anomaly_report",
          "description": "보고서 종류입니다."
        },
        "schema_version": {
          "type": "string",
          "minLength": 1,
          "description": "보고서 schema 버전입니다."
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "보고서 생성 시각입니다."
        },
        "language": {
          "type": "string",
          "const": "ko",
          "description": "보고서 표시 언어입니다."
        },
        "source_card_id": {
          "type": "string",
          "minLength": 1,
          "description": "보고서 생성 기준이 된 priority card ID입니다."
        },
        "agent_run_id": {
          "type": ["string", "null"],
          "description": "Agent 실행 ID입니다. 없으면 null입니다."
        }
      }
    },
    "target_asset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "substation_id",
        "asset_label",
        "configuration_type",
        "manufacturer_id",
        "window_start",
        "window_end"
      ],
      "properties": {
        "substation_id": {
          "type": ["integer", "string"],
          "description": "대상 열수송/열교환 설비 또는 지점 ID입니다."
        },
        "asset_label": {
          "type": "string",
          "minLength": 1,
          "description": "프론트에서 표시할 대상 설비명입니다."
        },
        "configuration_type": {
          "type": ["string", "null"],
          "description": "설비 구성 유형입니다."
        },
        "manufacturer_id": {
          "type": ["string", "null"],
          "description": "제조사 또는 데이터 출처 구분자입니다."
        },
        "window_start": {
          "type": "string",
          "format": "date-time",
          "description": "분석 구간 시작 시각입니다."
        },
        "window_end": {
          "type": "string",
          "format": "date-time",
          "description": "분석 구간 종료 시각입니다."
        },
        "location_label": {
          "type": ["string", "null"],
          "description": "프론트 표시용 위치명입니다."
        }
      }
    },
    "priority_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "priority_level",
        "priority_score",
        "operator_review",
        "confidence",
        "urgency"
      ],
      "properties": {
        "priority_level": {
          "type": "string",
          "enum": ["Urgent", "High", "Medium", "Low"],
          "description": "프론트 표시용 우선순위 등급입니다."
        },
        "priority_score": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 100,
          "description": "Priority Engine 또는 Agent Output에서 전달된 우선순위 점수입니다."
        },
        "operator_review": {
          "type": "string",
          "enum": ["Required", "Not Required"],
          "description": "운영자 검토 필요 여부입니다."
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"],
          "description": "보고서 판단 근거의 신뢰 수준입니다."
        },
        "urgency": {
          "type": "string",
          "enum": ["immediate", "today", "next_shift", "monitor"],
          "description": "권장 대응 시점입니다."
        },
        "priority_reason": {
          "type": ["string", "null"],
          "description": "우선순위가 산정된 핵심 이유입니다."
        }
      }
    },
    "situation_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headline", "summary", "current_status"],
      "properties": {
        "headline": {
          "type": "string",
          "minLength": 1,
          "description": "보고서 상단에 표시할 한 줄 제목입니다."
        },
        "summary": {
          "type": "string",
          "minLength": 1,
          "description": "이상징후 상황 요약입니다."
        },
        "current_status": {
          "type": "string",
          "minLength": 1,
          "description": "현재 운영 상태를 직원이 이해하기 쉬운 문장으로 요약합니다."
        },
        "impact_summary": {
          "type": ["string", "null"],
          "description": "예상 운영 영향 요약입니다."
        }
      }
    },
    "key_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "value", "interpretation", "confidence"],
        "properties": {
          "label": {
            "type": "string",
            "minLength": 1,
            "description": "근거 항목명입니다."
          },
          "value": {
            "type": ["string", "number", "boolean", "null"],
            "description": "근거 값입니다."
          },
          "unit": {
            "type": ["string", "null"],
            "description": "값의 단위입니다."
          },
          "interpretation": {
            "type": "string",
            "minLength": 1,
            "description": "운영자용 해석 문장입니다."
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "해당 근거의 신뢰 수준입니다."
          },
          "evidence_ref_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "description": "evidence_references의 ref_id 목록입니다."
          }
        }
      }
    },
    "risk_analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": ["risk_level", "risk_summary", "operational_impact", "monitoring_points"],
      "properties": {
        "risk_level": {
          "type": "string",
          "enum": ["Urgent", "High", "Medium", "Low"],
          "description": "운영상 위험 수준입니다."
        },
        "risk_summary": {
          "type": "string",
          "minLength": 1,
          "description": "위험 분석 요약입니다."
        },
        "operational_impact": {
          "type": "string",
          "minLength": 1,
          "description": "운영 영향 설명입니다."
        },
        "monitoring_points": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "추가로 확인할 모니터링 포인트입니다."
        }
      }
    },
    "suspected_causes": {
      "type": "array",
      "description": "단정이 아닌 가능성 기반 원인 후보 목록입니다.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["cause", "likelihood", "rationale"],
        "properties": {
          "cause": {
            "type": "string",
            "minLength": 1,
            "description": "의심 원인 후보입니다."
          },
          "likelihood": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "원인 가능성 수준입니다."
          },
          "rationale": {
            "type": "string",
            "minLength": 1,
            "description": "해당 원인을 의심하는 근거입니다."
          },
          "evidence_ref_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "description": "관련 evidence ref ID 목록입니다."
          }
        }
      }
    },
    "recommended_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action", "urgency", "owner_hint"],
        "properties": {
          "action": {
            "type": "string",
            "minLength": 1,
            "description": "권장 조치 내용입니다."
          },
          "urgency": {
            "type": "string",
            "enum": ["immediate", "today", "next_shift", "monitor"],
            "description": "조치 권장 시점입니다."
          },
          "owner_hint": {
            "type": ["string", "null"],
            "description": "조치 담당자 또는 담당 조직 힌트입니다."
          },
          "expected_outcome": {
            "type": ["string", "null"],
            "description": "조치 후 기대되는 확인 결과입니다."
          }
        }
      }
    },
    "work_order_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "work_order_issued",
        "status",
        "work_order_id",
        "summary",
        "evidence_refs"
      ],
      "properties": {
        "work_order_issued": {
          "type": "boolean",
          "description": "작업지시서 발행 여부입니다."
        },
        "status": {
          "type": "string",
          "enum": [
            "not_created",
            "drafted",
            "sent",
            "acknowledged",
            "in_progress",
            "completed",
            "cancelled"
          ],
          "description": "작업지시서 상태입니다."
        },
        "work_order_id": {
          "type": ["string", "null"],
          "description": "작업지시서 ID입니다. 미발행이면 null입니다."
        },
        "summary": {
          "type": ["string", "null"],
          "description": "작업지시서 전문이 아닌 짧은 요약입니다."
        },
        "evidence_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "작업지시서와 연결된 evidence ref ID 목록입니다."
        }
      }
    },
    "evidence_references": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref_id", "source_type", "title"],
        "properties": {
          "ref_id": {
            "type": "string",
            "minLength": 1,
            "description": "보고서 내부에서 참조하는 근거 ID입니다."
          },
          "source_type": {
            "type": "string",
            "enum": [
              "priority_card",
              "ops_evidence",
              "rag_document",
              "external_context",
              "model_output",
              "work_order"
            ],
            "description": "근거 출처 유형입니다."
          },
          "title": {
            "type": "string",
            "minLength": 1,
            "description": "근거 표시 제목입니다."
          },
          "source_id": {
            "type": ["string", "null"],
            "description": "원천 시스템의 ID입니다."
          },
          "uri": {
            "type": ["string", "null"],
            "description": "원문 또는 문서 위치입니다."
          },
          "excerpt": {
            "type": ["string", "null"],
            "description": "짧은 근거 발췌 또는 요약입니다."
          },
          "created_at": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "근거 생성 또는 수집 시각입니다."
          }
        }
      }
    },
    "operator_note": {
      "type": "object",
      "additionalProperties": false,
      "required": ["note", "review_required"],
      "properties": {
        "note": {
          "type": ["string", "null"],
          "description": "운영자에게 표시할 추가 메모입니다."
        },
        "review_required": {
          "type": "boolean",
          "description": "운영자 검토 필요 여부입니다."
        },
        "review_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "검토가 필요한 이유 목록입니다."
        }
      }
    },
    "rendering_hints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["display_title", "severity_badge", "section_order"],
      "properties": {
        "display_title": {
          "type": "string",
          "minLength": 1,
          "description": "HTML/PDF 제목으로 표시할 문구입니다."
        },
        "severity_badge": {
          "type": "object",
          "additionalProperties": false,
          "required": ["label", "level"],
          "properties": {
            "label": {
              "type": "string",
              "minLength": 1,
              "description": "프론트 배지 표시 문구입니다."
            },
            "level": {
              "type": "string",
              "enum": ["Urgent", "High", "Medium", "Low"],
              "description": "배지 색상 결정에 사용할 심각도입니다."
            },
            "color_hint": {
              "type": ["string", "null"],
              "description": "선택적 색상 힌트입니다."
            }
          }
        },
        "section_order": {
          "type": "array",
          "minItems": 12,
          "items": {
            "type": "string",
            "enum": [
              "report_metadata",
              "target_asset",
              "priority_summary",
              "situation_summary",
              "key_evidence",
              "risk_analysis",
              "suspected_causes",
              "recommended_actions",
              "work_order_summary",
              "evidence_references",
              "operator_note",
              "rendering_hints"
            ]
          },
          "description": "프론트와 HTML/PDF 렌더러가 사용할 섹션 표시 순서입니다."
        },
        "page_break_before": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "PDF 렌더링 시 페이지 나눔을 적용할 섹션 목록입니다."
        }
      }
    }
  }
}
